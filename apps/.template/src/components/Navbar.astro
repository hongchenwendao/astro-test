---
import siteConfig from '../../site.config';

const navLinks = [
  { label: '首页', href: '/' },
  { label: '工具', href: '/tool' },
  { label: '博客', href: '/blog' },
  { label: '定价', href: '/pricing' },
];

const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-icon">{{SITE_ICON}}</span>
      <span class="logo-text">{siteConfig.name}</span>
    </a>

    <div class="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href }]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <a href="/tool" class="nav-cta">
      免费试用 →
    </a>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0 24px;
    backdrop-filter: blur(20px);
    background: rgba(10, 10, 26, 0.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 18px;
    text-decoration: none;
    color: #f1f5f9;
  }

  .logo-icon {
    font-size: 22px;
  }

  .nav-links {
    display: flex;
    gap: 4px;
  }

  .nav-link {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #94a3b8;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .nav-link:hover {
    color: #e2e8f0;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link.active {
    color: #e2e8f0;
    background: rgba(99, 102, 241, 0.12);
  }

  .nav-cta {
    padding: 8px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 2px 12px rgba(99, 102, 241, 0.3);
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
  }
</style>
