---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { Footer } from '@saas/ui';
import ImageCompressor from '../tools/ImageCompressor';
import siteConfig from '../../site.config';
---

<Layout title="图片压缩" description="在浏览器中即时上传并压缩你的图片。">
  <Navbar />

  <section class="tool-section">
    <h1 class="tool-title">图片压缩器</h1>
    <p class="tool-desc">
      把图片拖到下方 — 压缩在浏览器中即时完成。
      <strong>不会上传到任何服务器。</strong>
    </p>

    <!-- React island — Astro 群岛模式 -->
    <ImageCompressor client:load accentColor={siteConfig.accentColor} />
  </section>

  <Footer
    
    siteName={siteConfig.name}
    sisterSites={siteConfig.sisterSites}
    accentColor={siteConfig.accentColor}
  />
</Layout>

<style>
  .tool-section {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 24px 80px;
  }

  .tool-title {
    font-size: 32px;
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 12px;
  }

  .tool-desc {
    font-size: 16px;
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .tool-desc strong {
    color: #a78bfa;
  }
</style>
