---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { Footer } from '@saas/ui';
import siteConfig from '../../site.config';

const features = [
  {
    icon: '🚀',
    title: '极速运行',
    desc: '在浏览器端直接运行，速度极快。',
  },
  {
    icon: '🔒',
    title: '绝对隐私',
    desc: '所有数据在本地处理，保护您的隐私安全。',
  },
  {
    icon: '✨',
    title: '永久免费',
    desc: '无需注册，核心功能完全免费使用。',
  },
];
// template-features-end
---

<Layout>
  <Navbar />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge">✨ 免费在线工具 — 无需注册</div>
    <h1 class="hero-title">
      免费合并 PDF <br />
      <span class="gradient-text">保护隐私不上传</span>
    </h1>
    <p class="hero-desc">
      {siteConfig.description}
    </p>
    <div class="hero-actions">
      <a href="/tool" class="btn-primary">开始压缩 →</a>
      <a href="/pricing" class="btn-secondary">查看定价</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">80%</span>
        <span class="stat-label">平均压缩率</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">0</span>
        <span class="stat-label">服务器上传</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">∞</span>
        <span class="stat-label">隐私保护</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features-section">
    <h2 class="section-title">为什么选择 {siteConfig.name}？</h2>
    <p class="section-subtitle">为你提供最极致的工具体验</p>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-icon">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-glow"></div>
    <h2>准备好开始使用了吗？</h2>
    <p>无需注册账号，马上体验。</p>
    <a href="/tool" class="btn-primary btn-lg">进入工具大厅 →</a>
  </section>

  <!-- Footer -->
  <Footer
    
    siteName={siteConfig.name}
    sisterSites={siteConfig.sisterSites}
    accentColor={siteConfig.accentColor}
  />
</Layout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 100px 24px 80px;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    color: #a78bfa;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    margin-bottom: 32px;
  }

  .hero-title {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f1f5f9;
    margin-bottom: 24px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #6366f1 0%, #a78bfa 50%, #c084fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 18px;
    line-height: 1.7;
    color: #94a3b8;
    max-width: 560px;
    margin: 0 auto 40px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 60px;
  }

  .btn-primary {
    padding: 14px 32px;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    box-shadow: 0 4px 24px rgba(99, 102, 241, 0.35);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.45);
  }

  .btn-secondary {
    padding: 14px 32px;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 600;
    color: #cbd5e1;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .btn-lg {
    padding: 18px 40px;
    font-size: 18px;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    padding: 24px 40px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(10px);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 800;
    color: #a78bfa;
  }

  .stat-label {
    font-size: 12px;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.08);
  }

  /* Features */
  .features-section {
    padding: 80px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    text-align: center;
    font-size: 32px;
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 8px;
  }

  .section-subtitle {
    text-align: center;
    color: #64748b;
    font-size: 16px;
    margin-bottom: 48px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .feature-card {
    padding: 28px 24px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    border-color: rgba(99, 102, 241, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(99, 102, 241, 0.08);
  }

  .feature-icon {
    font-size: 32px;
    margin-bottom: 16px;
  }

  .feature-card h3 {
    font-size: 16px;
    font-weight: 700;
    color: #e2e8f0;
    margin-bottom: 8px;
  }

  .feature-card p {
    font-size: 14px;
    line-height: 1.6;
    color: #94a3b8;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    padding: 80px 24px;
    position: relative;
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.12), transparent 70%);
    pointer-events: none;
  }

  .cta-section h2 {
    font-size: 36px;
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 12px;
    position: relative;
  }

  .cta-section p {
    font-size: 18px;
    color: #94a3b8;
    margin-bottom: 32px;
    position: relative;
  }

  .cta-section .btn-primary {
    position: relative;
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
    .hero-stats {
      flex-direction: column;
      gap: 16px;
    }
    .stat-divider {
      width: 60px;
      height: 1px;
    }
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
