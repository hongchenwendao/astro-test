---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { Footer } from '@saas/ui';
import JsonFormatter from '../tools/JsonFormatter';
import siteConfig from '../../site.config';
---

<Layout title="JSON 格式化" description="在线格式化、校验、压缩你的 JSON 数据。">
  <Navbar />

  <section class="tool-section">
    <h1 class="tool-title">JSON 格式化工具</h1>
    <p class="tool-desc">
      粘贴你的 JSON，一键美化或压缩。
      <strong>所有数据仅在浏览器本地处理。</strong>
    </p>

    <JsonFormatter client:load accentColor={siteConfig.accentColor} />
  </section>

  <Footer
    
    siteName={siteConfig.name}
    sisterSites={siteConfig.sisterSites}
    accentColor={siteConfig.accentColor}
  />
</Layout>

<style>
  .tool-section {
    max-width: 960px;
    margin: 0 auto;
    padding: 60px 24px 80px;
  }

  .tool-title {
    font-size: 32px;
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 12px;
  }

  .tool-desc {
    font-size: 16px;
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .tool-desc strong {
    color: #34d399;
  }
</style>
